        "print(\"--- Imputing remaining NaNs in df ---\")\n",
        "# Fill NaNs with the median of each column in its current (scaled) state\n",
        "for col in cols_with_nan:\n",
        "    if col in df.columns and df[col].isnull().any():\n",
        "        median_val = df[col].median()\n",
        "        df[col].fillna(median_val, inplace=True)\n",
        "        print(f\"Filled NaNs in '{col}' with median: {median_val:.4f}\")\n",
        "\n",
        "# Verify no more NaNs in these columns\n",
        "print(\"\\nMissing values after imputation in df (should be 0 for listed columns):\")\n",
        "print(df[cols_with_nan].isnull().sum())\n",
        "\n",
        "# 2. Calculate new features\n",
        "print(\"\\n--- Creating new features ---\")\n",
        "\n",
        "# Cashback per Order\n",
        "df['Cashback_per_Order'] = df['CashbackAmount'] / df['OrderCount']\n",
        "# Coupons per Order\n",
        "df['Coupons_per_Order'] = df['CouponUsed'] / df['OrderCount']\n",
        "# Devices per Address\n",
        "df['Devices_per_Address'] = df['NumberOfDeviceRegistered'] / df['NumberOfAddress']\n",
        "# Orders per Tenure Month\n",
        "df['Orders_per_Tenure_Month'] = df['OrderCount'] / df['Tenure']\n",
        "\n",
        "# 3. Handle division by zero / NaNs in new features\n",
        "# Replace any inf/-inf with NaN, then fill all NaNs with 0 (assuming ratio is 0 if denominator was effectively zero/NaN)\n",
