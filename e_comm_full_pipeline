      "source": [
        "def compare_missing_groups(df, target_col):\n",
        "    \"\"\"\n",
        "    Recreated helper: Compares the distributions of other features\n",
        "    when the target column is missing vs. when it is observed.\n",
        "    \"\"\"\n",
        "    print(f\"\\n=== Missingness Analysis for Column: {target_col} ===\")\n",
        "    is_missing = df[target_col].isna()\n",
        "\n",
        "    if not is_missing.any():\n",
        "        print(f\"No missing values found in '{target_col}'.\")\n",
        "        return\n",
        "\n",
        "    num_cols = df.select_dtypes(include='number').columns.drop(['CustomerID', 'Churn', target_col], errors='ignore')\n",
        "    for col in num_cols:\n",
        "        group_obs = df.loc[~is_missing, col].dropna()\n",
        "        group_miss = df.loc[is_missing, col].dropna()\n",
        "        if len(group_obs) > 1 and len(group_miss) > 1:\n",
        "            stat, p = ttest_ind(group_obs, group_miss, equal_var=False)\n",
        "            status = \"⚠️ Significant Difference\" if p < 0.05 else \"✅ Homogeneous\"\n",
        "            print(f\"Feature '{col}' mean by '{target_col}' missingness: p-value = {p:.4f} ({status})\")\n",
        "\n",
        "def chi_square_missingness(df, target_col, categorical_cols):\n",
        "    \"\"\"\n",
        "    Recreated helper: Checks if missingness in target_col is associated\n",
        "    with other categorical features.\n",
        "    \"\"\"\n",
        "    print(f\"\\n--- Chi-Square Missingness Association for {target_col} ---\")\n",
        "    df_copy = df.copy()\n",
        "    df_copy[f'{target_col}_is_missing'] = df_copy[target_col].isna().astype(str)\n",
        "\n",
        "    significant_cols = []\n",
        "    for col in categorical_cols:\n",
        "        if col != target_col:\n",
        "            contingency_df = pd.crosstab(df_copy[f'{target_col}_is_missing'], df_copy[col])\n",
        "            if not contingency_df.empty:\n",
        "                chi2, p, dof, expected = chi2_contingency(contingency_df)\n",
        "                print(f\"Missingness dependency on '{col}': p-value = {p:.4f}\")\n",
        "                if p < 0.05:\n",
        "                    significant_cols.append(col)\n",
        "    return categorical_cols # Return all of them anyway to maximize MICE context\n",
        "\n",
        "def ks_distribution_check(observed_values, imputed_values, col_name, dataset_name='Train'):\n",
        "    \"\"\"\n",
        "    Recreated helper: Compares original observed values against the\n",
        "    fully imputed array to make sure MICE didn't distort reality.\n",
        "    \"\"\"\n",
        "    obs = pd.Series(observed_values).dropna()\n",
        "    imp = pd.Series(imputed_values).dropna()\n",
        "    stat, p_val = ks_2samp(obs, imp)\n",
        "    status = \"⚠️ Distribution Distorted\" if p_val < 0.05 else \"✅ Distribution Preserved\"\n",
        "    print(f\"[{dataset_name}] KS Test for '{col_name}' Imputation: p-value = {p_val:.4f} ({status})\")\n",
        "\n",
        "\n",
        "def mice_impute_column(X_train, X_test, target_col, nominal_cols, min_value=None):\n",
        "    \"\"\"\n",
        "    Adapts automatically to BOTH numerical features (like Tenure)\n",
        "    and nominal features (like MaritalStatus).\n",
        "    \"\"\"\n",
        "    X_train_clean = X_train.copy()\n",
        "    X_test_clean = X_test.copy()\n",
        "\n",
        "    # Save the original observed states before they get filled\n",
        "    observed_train = X_train_clean[target_col].dropna().values\n",
        "    observed_test = X_test_clean[target_col].dropna().values\n",
        "\n",
        "    # 1. Identify context features\n",
        "    numerical_cols = X_train_clean.select_dtypes(include='number').columns.drop(['CustomerID', 'Churn'], errors='ignore').tolist()\n",
        "    if target_col in numerical_cols:\n",
        "        numerical_cols.remove(target_col)\n",
        "\n",
        "    other_nominal_cols = [col for col in nominal_cols if col != target_col]\n",
        "    all_predictors = numerical_cols + other_nominal_cols\n",
        "\n",
        "    # 2. Separate DataFrames\n",
        "    X_train_preds = X_train_clean[all_predictors].copy()\n",
        "    X_test_preds = X_test_clean[all_predictors].copy()\n",
        "\n",
        "    y_train_target = X_train_clean[[target_col]].copy()\n",
        "    y_test_target = X_test_clean[[target_col]].copy()\n",
        "\n",
        "    # 3. One-hot encode context features\n",
        "    X_train_encoded = pd.get_dummies(X_train_preds, columns=other_nominal_cols, drop_first=True, dummy_na=False)\n",
        "    X_test_encoded = pd.get_dummies(X_test_preds, columns=other_nominal_cols, drop_first=True, dummy_na=False)\n",
        "    X_train_encoded, X_test_encoded = X_train_encoded.align(X_test_encoded, join='left', axis=1, fill_value=0)\n",
        "\n",
        "    # 4. Target Encoding branch (Numerical vs. Categorical)\n",
        "    is_numeric_target = pd.api.types.is_numeric_dtype(X_train[target_col])\n",
        "\n",
        "    if is_numeric_target:\n",
        "        y_train_encoded = y_train_target\n",
        "        y_test_encoded = y_test_target\n",
        "    else:\n",
        "        target_mapping = {cat: idx for idx, cat in enumerate(y_train_target[target_col].dropna().unique())}\n",
        "        inverse_target_mapping = {idx: cat for cat, idx in target_mapping.items()}\n",
        "        y_train_encoded = y_train_target[target_col].map(target_mapping)\n",
        "        y_test_encoded = y_test_target[target_col].map(target_mapping)\n",
        "\n",
        "    # 5. Fit MICE Imputer\n",
        "    train_matrix = pd.concat([X_train_encoded, y_train_encoded], axis=1)\n",
        "    test_matrix = pd.concat([X_test_encoded, y_test_encoded], axis=1)\n",
        "\n",
        "    imputer = IterativeImputer(max_iter=10, random_state=42)\n",
        "    train_imputed = pd.DataFrame(imputer.fit_transform(train_matrix), columns=train_matrix.columns, index=train_matrix.index)\n",
        "    test_imputed = pd.DataFrame(imputer.transform(test_matrix), columns=test_matrix.columns, index=test_matrix.index)\n",
        "\n",
        "    # 6. Post-process target values\n",
        "    imputed_train_series = train_imputed[target_col]\n",
        "    imputed_test_series = test_imputed[target_col]\n",
        "\n",
        "    if is_numeric_target:\n",
        "        # If it's a number like Tenure, round it to whole integers (or clip at min_value)\n",
        "        if min_value is not None:\n",
        "            imputed_train_series = imputed_train_series.clip(lower=min_value)\n",
        "            imputed_test_series = imputed_test_series.clip(lower=min_value)\n",
        "        X_train_clean[target_col] = imputed_train_series.round()\n",
        "        X_test_clean[target_col] = imputed_test_series.round()\n",
        "    else:\n",
        "        # Categorical branch logic\n",
        "        imputed_train_target = imputed_train_series.round().astype(int).clip(0, len(target_mapping) - 1)\n",
        "        imputed_test_target = imputed_test_series.round().astype(int).clip(0, len(target_mapping) - 1)\n",
        "        X_train_clean[target_col] = imputed_train_target.map(inverse_target_mapping)\n",
        "        X_test_clean[target_col] = imputed_test_target.map(inverse_target_mapping)\n",
        "\n",
        "    # Return exactly what your pipeline cells expect\n",
        "    full_train_array = X_train_clean[target_col].values\n",
        "    full_test_array = X_test_clean[target_col].values\n",
        "\n",
        "    return observed_train, full_train_array, observed_test, full_test_array, X_train_clean, X_test_clean"
      ]
    },
