        "cols_with_nan = [\n",
        "    'Tenure', 'WarehouseToHome', 'HourSpendOnApp',\n",
        "    'OrderAmountHikeFromlastYear', 'CouponUsed', 'OrderCount', 'DaySinceLastOrder'\n",
