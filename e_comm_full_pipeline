    {
      "cell_type": "code",
      "source": [
        "columns_for_winsorization = ['WarehouseToHome']\n",
        "columns_for_dropping = ['NumberOfAddress']\n",
        "\n",
        "outlier_rows_to_drop = pd.Index([]) # Initialize an empty index for rows to be dropped\n",
        "\n",
        "print(\"--- Handling WarehouseToHome (Winsorization) ---\")\n",
        "for col in columns_for_winsorization:\n",
        "    Q1 = df[col].quantile(0.25)\n",
        "    Q3 = df[col].quantile(0.75)\n",
        "    IQR = Q3 - Q1\n",
        "    lower_bound = Q1 - 1.5 * IQR\n",
        "    upper_bound = Q3 + 1.5 * IQR\n",
        "\n",
        "    # Count potential outliers for reporting\n",
        "    potential_outliers_count = df[(df[col] < lower_bound) | (df[col] > upper_bound)].shape[0]\n",
        "    print(f\"Number of values outside 1.5*IQR range in '{col}' before Winsorization: {potential_outliers_count}\")\n",
        "\n",
        "    # Apply Winsorization (clip values)\n",
        "    df[col] = np.clip(df[col], lower_bound, upper_bound)\n",
        "    print(f\"Values in '{col}' have been Winsorized (capped at {lower_bound:.2f} and {upper_bound:.2f}).\")\n",
        "\n",
        "print(\"\\n--- Handling NumberOfAddress (Dropping Outliers) ---\")\n",
        "for col in columns_for_dropping:\n",
        "    Q1 = df[col].quantile(0.25)\n",
        "    Q3 = df[col].quantile(0.75)\n",
        "    IQR = Q3 - Q1\n",
        "    lower_bound = Q1 - 1.5 * IQR\n",
        "    upper_bound = Q3 + 1.5 * IQR\n",
        "\n",
        "    # Identify indices of outliers for the current column to be dropped\n",
        "    current_col_outlier_indices = df[(df[col] < lower_bound) | (df[col] > upper_bound)].index\n",
        "    outliers_count = len(current_col_outlier_indices)\n",
        "    print(f\"Number of outliers detected in '{col}' for dropping: {outliers_count}\")\n",
        "\n",
        "    # Add these indices to the collective set of rows to drop\n",
        "    outlier_rows_to_drop = outlier_rows_to_drop.union(current_col_outlier_indices)\n",
        "\n",
        "print(f\"\\nTotal unique rows identified for dropping across '{', '.join(columns_for_dropping)}': {len(outlier_rows_to_drop)}\")\n",
        "\n",
        "# Drop the identified rows if any\n",
        "original_rows = df.shape[0]\n",
        "if not outlier_rows_to_drop.empty:\n",
        "    df = df.drop(outlier_rows_to_drop)\n",
        "    rows_dropped = original_rows - df.shape[0]\n",
        "    print(f\"Dropped {rows_dropped} rows containing outliers from '{', '.join(columns_for_dropping)}'.\")\n",
        "else:\n",
        "    print(\"No rows were dropped as no outliers were found in 'NumberOfAddress'.\")\n",
        "\n",
        "print(f\"New DataFrame shape: {df.shape}\")\n",
        "\n",
        "# Display summary statistics to confirm changes\n",
        "print(\"\\nSummary statistics after outlier handling:\")\n",
        "print(df[columns_for_winsorization + columns_for_dropping].describe())"
